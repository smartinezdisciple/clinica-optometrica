# =============================================================================
# VARIABLES DE ENTORNO — Sistema Clínica Optométrica
# Copia este archivo como .env y rellena los valores reales
# NUNCA commites el archivo .env al repositorio
# =============================================================================

# ── Aplicación ─────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=clinica_optometrica
DB_USER=clinica_user
DB_PASSWORD=TuPasswordAqui
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_SSL=false

# ── JWT ────────────────────────────────────────────────────────────────────────
# Genera secrets seguros con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=cambia_este_secret_access_minimo_32_caracteres_xxxxxxxxxxxxxxxxxxx
JWT_REFRESH_SECRET=cambia_este_secret_refresh_minimo_32_caracteres_xxxxxxxxxxxxxxxxx
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── SMTP (Recuperación de contraseña) ──────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu@gmail.com
SMTP_PASS=tu_app_password
SMTP_FROM="Dr. Lentes Sistema <no-reply@drlentes.com>"
